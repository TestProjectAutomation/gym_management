# Production Environment Variables
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=gym.example.com,www.gym.example.com,api.gym.example.com

# Database - Production
DB_NAME=gym_production_db
DB_HOST=production-db.xxxxxx.us-east-1.rds.amazonaws.com
DB_SSL_MODE=require

# Redis - Production
REDIS_URL=rediss://:password@production-redis.xxxxxx.us-east-1.elasticache.amazonaws.com:6379/0

# Security - Production
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000  # 1 year
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# Rate Limiting - Production
RATE_LIMIT_REQUESTS=50
RATE_LIMIT_PERIOD=60  # seconds

# Logging - Production
LOG_LEVEL=WARNING
LOG_FILE=/var/log/gym/gym_prod.log

# Monitoring
SENTRY_ENVIRONMENT=production